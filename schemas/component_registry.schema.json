{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/design-fidelity/component_registry.schema.json",
  "title": "Figma To iOS Component Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "components"],
  "properties": {
    "registry_version": { "type": "string", "minLength": 1 },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentMapping" }
    }
  },
  "$defs": {
    "componentMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "figma_component_name",
        "figma_node_id",
        "ios_component",
        "ios_import_path",
        "props",
        "allowed_props",
        "required_tokens",
        "forbidden_implementations",
        "usage_rule",
        "status",
        "agent_review_status",
        "human_review_status",
        "traceback_refs",
        "candidate_baseline",
        "accepted_baseline"
      ],
      "properties": {
        "figma_component_name": { "type": "string", "minLength": 1 },
        "figma_node_id": { "type": "string", "minLength": 1 },
        "ios_component": { "type": "string" },
        "ios_import_path": { "type": "string" },
        "props": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null", "array", "object"]
          }
        },
        "allowed_props": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "required_tokens": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "forbidden_implementations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "usage_rule": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": [
            "ready_for_use",
            "needs_fix",
            "requires_human_review",
            "blocked",
            "deprecated"
          ]
        },
        "agent_review_status": {
          "type": "string",
          "enum": [
            "not_reviewed",
            "in_progress",
            "passed",
            "failed",
            "requires_human_review",
            "blocked"
          ]
        },
        "human_review_status": {
          "type": "string",
          "enum": [
            "not_requested",
            "pending",
            "accepted",
            "changes_requested"
          ]
        },
        "component_diff_report_path": { "type": ["string", "null"] },
        "traceback_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "candidate_baseline": { "type": ["string", "null"] },
        "accepted_baseline": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "ready_for_use" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "agent_review_status": { "const": "passed" },
              "ios_component": { "minLength": 1 },
              "ios_import_path": { "minLength": 1 },
              "component_diff_report_path": { "type": "string", "minLength": 1 },
              "candidate_baseline": { "type": "string", "minLength": 1 }
            },
            "required": ["component_diff_report_path"]
          }
        }
      ]
    }
  }
}

