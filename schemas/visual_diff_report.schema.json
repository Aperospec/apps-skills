{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/design-fidelity/visual_diff_report.schema.json",
  "title": "Screen Visual Difference Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "screen_name",
    "figma_reference",
    "runtime_screenshot",
    "generated_at",
    "status",
    "issues"
  ],
  "properties": {
    "report_id": { "type": "string", "minLength": 1 },
    "screen_name": { "type": "string", "minLength": 1 },
    "figma_reference": { "type": "string", "minLength": 1 },
    "runtime_screenshot": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "requires_human_review"]
    },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "region_name",
        "severity",
        "diff_type",
        "figma_expected",
        "runtime_actual",
        "likely_cause",
        "required_fix",
        "suggested_component",
        "suggested_token",
        "auto_fixable",
        "traceback_layer",
        "requires_human_review"
      ],
      "properties": {
        "issue_id": { "type": "string", "minLength": 1 },
        "region_name": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "blocker"]
        },
        "diff_type": {
          "type": "string",
          "enum": [
            "component_mismatch",
            "layout_mismatch",
            "spacing_mismatch",
            "typography_mismatch",
            "color_mismatch",
            "icon_mismatch",
            "image_mismatch",
            "state_mismatch",
            "safe_area_mismatch",
            "unknown"
          ]
        },
        "figma_expected": { "type": "string", "minLength": 1 },
        "runtime_actual": { "type": "string", "minLength": 1 },
        "likely_cause": { "type": "string", "minLength": 1 },
        "required_fix": { "type": "string", "minLength": 1 },
        "suggested_component": { "type": ["string", "null"] },
        "suggested_token": { "type": ["string", "null"] },
        "auto_fixable": { "type": "boolean" },
        "traceback_layer": {
          "type": "string",
          "enum": [
            "screen_assembly",
            "component_implementation",
            "design_token",
            "figma_mapping",
            "rendering_difference",
            "unknown"
          ]
        },
        "requires_human_review": { "type": "boolean" }
      }
    }
  }
}

